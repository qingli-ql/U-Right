{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pwd)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(rg *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(swift build *)",
      "Bash(swift test *)"
    ],
    "ask": [
      "Bash(xcodebuild *)",
      "Bash(codesign *)",
      "Bash(productbuild *)",
      "Bash(spctl *)",
      "Bash(open *)",
      "Bash(killall Finder)",
      "Bash(git push *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./Certificates/**)",
      "Read(./*.p12)",
      "Read(./*.mobileprovision)"
    ],
    "defaultMode": "acceptEdits"
  }
}
