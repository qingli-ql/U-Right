{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist/main",
    "rootDir": "./src",
    "types": ["node", "electron"],
    "lib": ["ES2022"]
  },
  "include": ["src/main/**/*.ts", "src/shared/**/*.ts"]
}
